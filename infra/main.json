{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.43.1.21952",
      "templateHash": "339161976459435017"
    }
  },
  "parameters": {
    "prefix": {
      "type": "string",
      "metadata": {
        "description": "Prefixo para nomear recursos (use algo curto, ex: tc4fb)"
      }
    },
    "envName": {
      "type": "string",
      "defaultValue": "demo",
      "metadata": {
        "description": "Ambiente para compor nomes (ex.: demo, dev, prod)."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Regiao dos recursos (input location do workflow Infra deploy; ex.: eastus, westus2)."
      }
    },
    "feedbackTableName": {
      "type": "string",
      "defaultValue": "feedbacks",
      "metadata": {
        "description": "Nome da tabela no Azure Table Storage"
      }
    },
    "azureHttpTimeoutSeconds": {
      "type": "int",
      "defaultValue": 10,
      "metadata": {
        "description": "Timeout (segundos) para chamadas do SDK Azure no runtime"
      }
    },
    "functionAppBaseName": {
      "type": "string",
      "defaultValue": "[format('{0}-func', parameters('prefix'))]",
      "metadata": {
        "description": "Nome base da Function App (sem sufixo). Ex.: tc4fb-func"
      }
    },
    "functionAppUseUniqueSuffix": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Adicionar sufixo único no nome da Function App (útil quando precisa de nomes globais sem conflito)"
      }
    }
  },
  "variables": {
    "tableStorageName": "[toLower(replace(format('{0}{1}tblstg', parameters('prefix'), parameters('envName')), '-', ''))]",
    "funcStorageName": "[toLower(replace(format('{0}{1}fnstg', parameters('prefix'), parameters('envName')), '-', ''))]",
    "appInsightsName": "[format('{0}-appi', parameters('prefix'))]",
    "planName": "[format('{0}-plan', parameters('prefix'))]",
    "functionAppName": "[if(parameters('functionAppUseUniqueSuffix'), toLower(replace(format('{0}-{1}', parameters('functionAppBaseName'), uniqueString(resourceGroup().id)), '_', '-')), toLower(replace(parameters('functionAppBaseName'), '_', '-')))]"
  },
  "resources": [
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2023-01-01",
      "name": "[variables('tableStorageName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Standard_LRS"
      },
      "kind": "StorageV2",
      "properties": {
        "minimumTlsVersion": "TLS1_2",
        "allowBlobPublicAccess": false
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts/tableServices",
      "apiVersion": "2023-01-01",
      "name": "[format('{0}/{1}', variables('tableStorageName'), 'default')]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', variables('tableStorageName'))]"
      ]
    },
    {
      "type": "Microsoft.Storage/storageAccounts/tableServices/tables",
      "apiVersion": "2023-01-01",
      "name": "[format('{0}/{1}/{2}', variables('tableStorageName'), 'default', parameters('feedbackTableName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts/tableServices', variables('tableStorageName'), 'default')]"
      ]
    },
    {
      "type": "Microsoft.Storage/storageAccounts/queueServices",
      "apiVersion": "2023-01-01",
      "name": "[format('{0}/{1}', variables('tableStorageName'), 'default')]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', variables('tableStorageName'))]"
      ]
    },
    {
      "type": "Microsoft.Storage/storageAccounts/queueServices/queues",
      "apiVersion": "2023-01-01",
      "name": "[format('{0}/{1}/{2}', variables('tableStorageName'), 'default', 'critical-feedback')]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts/queueServices', variables('tableStorageName'), 'default')]"
      ]
    },
    {
      "type": "Microsoft.Storage/storageAccounts/blobServices",
      "apiVersion": "2023-01-01",
      "name": "[format('{0}/{1}', variables('tableStorageName'), 'default')]",
      "properties": {
        "deleteRetentionPolicy": {
          "enabled": false
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', variables('tableStorageName'))]"
      ]
    },
    {
      "type": "Microsoft.Storage/storageAccounts/blobServices/containers",
      "apiVersion": "2023-01-01",
      "name": "[format('{0}/{1}/{2}', variables('tableStorageName'), 'default', 'relatorios')]",
      "properties": {
        "publicAccess": "None"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts/blobServices', variables('tableStorageName'), 'default')]"
      ]
    },
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2023-01-01",
      "name": "[variables('funcStorageName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Standard_LRS"
      },
      "kind": "StorageV2",
      "properties": {
        "minimumTlsVersion": "TLS1_2",
        "allowBlobPublicAccess": false
      }
    },
    {
      "type": "Microsoft.Insights/components",
      "apiVersion": "2020-02-02",
      "name": "[variables('appInsightsName')]",
      "location": "[parameters('location')]",
      "kind": "web",
      "properties": {
        "Application_Type": "web"
      }
    },
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2022-09-01",
      "name": "[variables('planName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Y1",
        "tier": "Dynamic"
      },
      "properties": {
        "reserved": true
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2022-09-01",
      "name": "[variables('functionAppName')]",
      "location": "[parameters('location')]",
      "kind": "functionapp,linux",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('planName'))]",
        "httpsOnly": true,
        "siteConfig": {
          "linuxFxVersion": "Java|21",
          "appSettings": [
            {
              "name": "FUNCTIONS_EXTENSION_VERSION",
              "value": "~4"
            },
            {
              "name": "FUNCTIONS_WORKER_RUNTIME",
              "value": "java"
            },
            {
              "name": "JAVA_VERSION",
              "value": "21"
            },
            {
              "name": "AzureWebJobsStorage",
              "value": "[format('DefaultEndpointsProtocol=https;AccountName={0};AccountKey={1};EndpointSuffix={2}', variables('funcStorageName'), listKeys(resourceId('Microsoft.Storage/storageAccounts', variables('funcStorageName')), '2023-01-01').keys[0].value, environment().suffixes.storage)]"
            },
            {
              "name": "WEBSITE_RUN_FROM_PACKAGE",
              "value": "1"
            },
            {
              "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
              "value": "[reference(resourceId('Microsoft.Insights/components', variables('appInsightsName')), '2020-02-02').ConnectionString]"
            },
            {
              "name": "APPINSIGHTS_INSTRUMENTATIONKEY",
              "value": "[reference(resourceId('Microsoft.Insights/components', variables('appInsightsName')), '2020-02-02').InstrumentationKey]"
            },
            {
              "name": "ApplicationInsightsAgent_EXTENSION_VERSION",
              "value": "~3"
            },
            {
              "name": "XDT_MicrosoftApplicationInsights_Mode",
              "value": "recommended"
            },
            {
              "name": "AZURE_STORAGE_CONNECTION_STRING",
              "value": "[format('DefaultEndpointsProtocol=https;AccountName={0};AccountKey={1};EndpointSuffix={2}', variables('tableStorageName'), listKeys(resourceId('Microsoft.Storage/storageAccounts', variables('tableStorageName')), '2023-01-01').keys[0].value, environment().suffixes.storage)]"
            },
            {
              "name": "AzureWebJobsDataStorage",
              "value": "[format('DefaultEndpointsProtocol=https;AccountName={0};AccountKey={1};EndpointSuffix={2}', variables('tableStorageName'), listKeys(resourceId('Microsoft.Storage/storageAccounts', variables('tableStorageName')), '2023-01-01').keys[0].value, environment().suffixes.storage)]"
            },
            {
              "name": "FEEDBACK_TABLE_NAME",
              "value": "[parameters('feedbackTableName')]"
            },
            {
              "name": "CRITICAL_FEEDBACK_QUEUE_NAME",
              "value": "critical-feedback"
            },
            {
              "name": "WEEKLY_REPORT_CONTAINER",
              "value": "relatorios"
            },
            {
              "name": "AZURE_HTTP_TIMEOUT_SECONDS",
              "value": "[string(parameters('azureHttpTimeoutSeconds'))]"
            }
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Insights/components', variables('appInsightsName'))]",
        "[resourceId('Microsoft.Storage/storageAccounts/queueServices/queues', variables('tableStorageName'), 'default', 'critical-feedback')]",
        "[resourceId('Microsoft.Storage/storageAccounts', variables('funcStorageName'))]",
        "[resourceId('Microsoft.Web/serverfarms', variables('planName'))]",
        "[resourceId('Microsoft.Storage/storageAccounts/blobServices/containers', variables('tableStorageName'), 'default', 'relatorios')]",
        "[resourceId('Microsoft.Storage/storageAccounts', variables('tableStorageName'))]"
      ]
    }
  ],
  "outputs": {
    "resourceGroupName": {
      "type": "string",
      "value": "[resourceGroup().name]"
    },
    "locationOut": {
      "type": "string",
      "value": "[parameters('location')]"
    },
    "functionAppName": {
      "type": "string",
      "value": "[variables('functionAppName')]"
    },
    "feedbackTableNameOut": {
      "type": "string",
      "value": "[parameters('feedbackTableName')]"
    },
    "tableStorageAccountName": {
      "type": "string",
      "value": "[variables('tableStorageName')]"
    },
    "funcStorageAccountName": {
      "type": "string",
      "value": "[variables('funcStorageName')]"
    }
  }
}